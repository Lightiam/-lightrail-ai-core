    (date "2026-04-08")
    (rev "A01")
    (company "LightRail")
    (comment 1 "PCIe Full-Height Half-Length (FHHL): 167.65 x 111.15 mm")
    (comment 2 "4-layer Megtron 6 stackup -- see Setup > Board Stackup")
    (comment 3 "PLACEHOLDERS: replace footprints with vendor parts before fab")
  )

  ;; -------------------------------------------------------------------------
  ;; Layer definitions
  ;; -------------------------------------------------------------------------
  (layers
    (0  "F.Cu"      signal)
    (1  "In1.Cu"    power   "GND plane")
    (2  "In2.Cu"    power   "PWR plane")
    (31 "B.Cu"      signal)
    (32 "B.Adhes"   user    "B.Adhesive")
    (33 "F.Adhes"   user    "F.Adhesive")
    (34 "B.Paste"   user)
    (35 "F.Paste"   user)
    (36 "B.SilkS"   user    "B.Silkscreen")
